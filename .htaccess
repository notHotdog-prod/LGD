# ============================================================
# letsgrowdigital.ai — Apache config (Hostinger)
# Primary goal: keep HTML fresh so design/copy changes propagate
# immediately, while letting browsers cache images/fonts long-term.
# ============================================================

# Force HTTPS and the canonical (non-www) host
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP -> HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirect www -> non-www (canonical is letsgrowdigital.ai)
  RewriteCond %{HTTP_HOST} ^www\.letsgrowdigital\.ai$ [NC]
  RewriteRule ^ https://letsgrowdigital.ai%{REQUEST_URI} [L,R=301]
</IfModule>

# Cache control — different rules per file type
<IfModule mod_headers.c>
  # HTML — always revalidate so the latest deploy shows immediately
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Static assets — long cache, safe to do since filenames are stable
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # CSS / JS — when we eventually have them as separate files (currently inline)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>

  # Plain text knowledge base (for AI crawlers) — short cache so updates ship fast
  <FilesMatch "\.(txt)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# Modern security headers — defense in depth, no behavior change
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(self), camera=()"
  # HSTS — only enable after confirming HTTPS works on every page (Hostinger usually fine)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Compression — smaller payload, faster load
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/plain text/xml application/xml
</IfModule>

# Custom error pages — fall back to homepage rather than ugly Apache 404
ErrorDocument 404 /index.html
